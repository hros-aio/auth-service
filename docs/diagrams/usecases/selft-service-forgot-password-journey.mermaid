flowchart TD
    A([User clicks Forgot password]) --> B[Enter tenant and email]
    B --> C{Self-service enabled?}
    C -- No --> D[Show Contact administrator]
    C -- Yes --> E[Submit reset request]
    E --> F[Show generic confirmation]
    F --> G[Receive verification code by email]
    G --> H[Enter verification code]
    H --> I{Code valid and unexpired?}
    I -- No --> J[Show invalid/expired code]
    J --> K{Retry allowed?}
    K -- Yes --> H
    K -- No --> E
    I -- Yes --> L[Receive temporary reset grant]
    L --> M[Enter new password]
    M --> N{Password valid and grant active?}
    N -- No --> O[Show password/grant error]
    O --> M
    N -- Yes --> P[Password updated]
    P --> Q[All sessions revoked]
    Q --> R([Return to login])
