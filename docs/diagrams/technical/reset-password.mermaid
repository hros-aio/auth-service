sequenceDiagram
    autonumber
    actor AD as Admin
    actor U as Target User
    participant AP as Admin Portal
    participant API as AdminUserSecurityController
    participant AZ as Authorization Domain
    participant P as PasswordApplicationService
    participant DB as PostgreSQL
    participant R as Redis
    participant E as Email Service
    participant A as Audit Platform

    AD->>AP: click Reset password
    AP->>API: POST /admin/users/{targetId}/password-reset
    API->>AZ: authorize(access.user.reset-password, target)
    alt unauthorized or cross-tenant
        AZ-->>API: deny
        API-->>AP: AUTH_PERMISSION_DENIED
    else authorized
        AZ-->>API: allow
        API->>P: requestAdminReset(actor,target)
        P->>DB: validate target lifecycle and tenant
        P->>R: store OTP with ADMIN_RESET_PASSWORD purpose and actorId
        P->>E: email OTP to target user
        P->>A: admin.reset.password.requested(actor,target)
        P-->>API: initiated
        API-->>AP: reset email sent

        U->>P: verify OTP through public reset endpoint
        P->>R: verify code and issue grant(purpose=ADMIN_RESET_PASSWORD, actorId)
        U->>P: submit new password with grant
        P->>DB: update credential, securityVersion++
        P->>R: revoke all sessions, consume grant
        P->>E: send reset confirmation
        P->>A: password.reset.completed(actor,target)
    end
