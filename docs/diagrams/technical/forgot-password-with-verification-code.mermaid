sequenceDiagram
    autonumber
    actor U as User
    participant FE as Web Frontend
    participant API as PasswordController
    participant P as PasswordApplicationService
    participant DB as PostgreSQL
    participant R as Redis
    participant E as Email Service
    participant C as CredentialService
    participant A as Audit Platform

    U->>FE: request forgot password
    FE->>API: POST /password/forgot/request {tenant,email}
    API->>P: requestForgotPassword()
    P->>DB: load authentication settings
    alt Need Admin Reset Password enabled
        P-->>API: AUTH_PASSWORD_RESET_DISABLED
        API-->>FE: contact administrator
    else self-service enabled
        P->>DB: resolve eligible user
        alt user unresolved or ineligible
            P->>R: apply IP/fingerprint rate limit only
            P->>A: forgot.password.requested(generic outcome)
            P-->>API: generic accepted response
        else eligible user
            P->>P: generate OTP and hash
            P->>R: store reset code(TTL=5m, purpose=SELF_SERVICE)
            P->>E: send OTP to primary email
            P->>A: forgot.password.requested
            P-->>API: generic accepted response
        end
    end

    U->>FE: submit OTP
    FE->>API: POST /password/forgot/verify
    API->>P: verifyResetCode(requestId, code)
    P->>R: verify and consume code atomically
    alt invalid or expired
        P-->>API: reset code invalid/expired
    else valid
        P->>R: create short-lived reset grant
        P-->>API: resetGrant
    end

    U->>FE: submit new password with grant
    FE->>API: POST /password/forgot/complete
    API->>P: setPasswordWithGrant(grant,password)
    P->>R: validate unconsumed grant
    P->>C: validate and hash password
    P->>DB: BEGIN
    P->>DB: update Credential(ACTIVE)
    P->>DB: increment User.securityVersion
    P->>DB: COMMIT
    P->>R: consume grant atomically
    P->>R: revoke all user sessions
    P->>A: password.reset.completed
    P-->>API: success
    API-->>FE: redirect to login
